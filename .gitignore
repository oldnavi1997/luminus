# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — solo excluir archivos con credenciales reales
.env
.env.local
.env.*.local
# .env.example se commitea (no tiene credenciales reales)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# DB dumps and ad-hoc SQL scripts (may contain credentials or data)
*.dump
*.dump.toc.txt
backups/
users_dump.sql
products_railway.sql
scripts/

# Tool / IDE local config
.agents/
.claude/
.junie/
.vscode/
