generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  IN_PROCESS
  CANCELLED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  role          Role      @default(USER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    String?
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  products    Product[]  @relation("ProductCategories")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Product {
  id                String                @id @default(cuid())
  name              String
  slug              String                @unique
  description       String?
  price             Decimal               @db.Decimal(10, 2)
  comparePrice      Decimal?              @db.Decimal(10, 2)
  stock             Int                   @default(0)
  images            String[]
  brand             String?
  frameType         String?
  frameMaterial     String?
  frameColor        String?
  lensType          String?
  gender            String?
  dimTotalWidth     String?
  dimLensWidth      String?
  dimFrameHeight    String?
  dimBridgeWidth    String?
  dimTempleLength   String?
  featured          Boolean               @default(false)
  active            Boolean               @default(true)
  primaryCategoryId String?
  categories        Category[]            @relation("ProductCategories")
  orderItems        OrderItem[]
  colorVariants     ProductColorVariant[] @relation("ProductVariants")
  isVariantOf       ProductColorVariant[] @relation("ProductIsVariantOf")
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

model ProductColorVariant {
  productId String
  variantId String
  product   Product @relation("ProductVariants", fields: [productId], references: [id], onDelete: Cascade)
  variant   Product @relation("ProductIsVariantOf", fields: [variantId], references: [id], onDelete: Cascade)

  @@id([productId, variantId])
}

model Order {
  id               String        @id @default(cuid())
  orderNumber      String        @unique
  userId           String?
  user             User?         @relation(fields: [userId], references: [id])
  guestEmail       String?
  shippingName     String
  shippingEmail    String
  shippingPhone    String?
  shippingAddress  String
  shippingCity     String
  shippingProvince String
  shippingPostal   String
  shippingCountry  String        @default("Argentina")
  subtotal         Decimal       @db.Decimal(10, 2)
  shippingCost     Decimal       @db.Decimal(10, 2) @default(0)
  discount         Decimal       @db.Decimal(10, 2) @default(0)
  total            Decimal       @db.Decimal(10, 2)
  mpPreferenceId   String?
  mpPaymentId      String?
  mpStatus         String?
  paymentStatus    PaymentStatus @default(PENDING)
  orderStatus      OrderStatus   @default(PENDING)
  items            OrderItem[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)
}
